# ──────────────────────────────────────────────────────────────────────────────
# Prospera — environment variable reference
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local or any file containing real secrets.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (docker compose): use the value below as-is
# Managed Postgres (Vercel / Neon / Supabase): paste your connection string
DATABASE_URL=postgresql://prospera:prospera@localhost:5432/prospera

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local dev (docker compose): use the value below as-is
# Managed Redis (Upstash / Vercel KV): paste your rediss:// URL
REDIS_URL=redis://localhost:6379

# ── Auth.js v5 ────────────────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32  (min 32 chars, required)
AUTH_SECRET=your-32-char-secret-here
# AUTH_URL=http://localhost:3000   # optional; auto-detected in most environments

# GitHub OAuth — optional but recommended
# Create OAuth app at https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=your-github-client-id
AUTH_GITHUB_SECRET=your-github-client-secret

# ── AI providers ─────────────────────────────────────────────────────────────
# Set AI_PROVIDER to the provider you want to use for the agent.
# Only the matching key needs to be set; others are ignored.
AI_PROVIDER=anthropic        # anthropic | openai | google
AI_MODEL=claude-sonnet-4-6   # model slug passed to the provider

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...        # REQUIRED for document embeddings (text-embedding-3-small)
                             # even when AI_PROVIDER=anthropic or google
GOOGLE_GENERATIVE_AI_API_KEY=AIza...

# ── Agent tools ──────────────────────────────────────────────────────────────
# TAVILY_API_KEY — web search (free tier at https://tavily.com)
# Without this key, web search tool returns a graceful error message.
# The code sandbox and weather tools require no API key.
TAVILY_API_KEY=tvly-...

# ── Misc ──────────────────────────────────────────────────────────────────────
# Set to 'true' during Docker build to skip env validation (build-time has no secrets)
# SKIP_ENV_VALIDATION=true
